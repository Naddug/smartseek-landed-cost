# ORTAQ v2 — environment variables
# Copy to .env and fill in values.

# ── Required ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# ── Database (recommended for production OAuth account linking) ─────────────
# If Postgres is unreachable, ORTAQ falls back to a secure file-backed auth store
# under data/store/ (local dev). Production should use a managed Postgres URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ortaq

# ── Google OAuth (recommended) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LinkedIn OAuth (optional) ─────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Email magic link (optional — requires DATABASE_URL + SMTP) ───────────────
EMAIL_SERVER=
EMAIL_FROM=noreply@ortaq.biz

# ── Internal / QA only ──────────────────────────────────────────────────────
# ORTAQ_ENABLE_DEMO_AUTH=true enables demo@ortaq.biz / ortak@ortaq.biz (password: demo)
