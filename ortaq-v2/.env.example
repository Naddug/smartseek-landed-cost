# ORTAQ v2 — environment variables
# Copy to .env and fill in values.

# ── Required (all environments) ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# ── Database (required for real registration / OAuth persistence) ───────────
# Without DATABASE_URL only demo credentials work:
#   demo@ortaq.biz / demo  (fırsat sahibi)
#   ortak@ortaq.biz / demo (ortak)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ortaq

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LinkedIn OAuth (optional) ─────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Email magic link (optional — requires DATABASE_URL) ───────────────────────
# Example: smtp://user:pass@smtp.example.com:587
EMAIL_SERVER=
EMAIL_FROM=noreply@ortaq.biz
