{
  "name": "ortaq-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "smoke:auth": "node --experimental-strip-types --experimental-loader ./scripts/_alias-loader.mjs scripts/smoke-auth.ts",
    "smoke:auth:api": "node --experimental-strip-types --experimental-loader ./scripts/_alias-loader.mjs scripts/smoke-auth-api.ts",
    "smoke:auth:session": "node --experimental-strip-types --experimental-loader ./scripts/_alias-loader.mjs scripts/smoke-auth-session.ts",
    "smoke": "npm run smoke:auth && npm run smoke:auth:api && npm run smoke:auth:session",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "pg": "^8.22.0",
    "react": "^18",
    "react-dom": "^18",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
