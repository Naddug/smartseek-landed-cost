# ORTAQ Web — environment variables (copy to .env.local)

# Public site URL (production: https://ortaq.biz)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# App environment: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Lead capture (homepage form) — Resend email delivery
# Production: RESEND_API_KEY required; RESEND_FROM_EMAIL must use a verified domain in Resend.
# Success is returned only when Resend accepts the send (delivered: true).
# Non-production: failed/missing delivery returns 503 with test: true (never fake success).
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=destek@ortaq.biz
RESEND_FROM_EMAIL=ORTAQ Başvuru <basvuru@ortaq.biz>

# Trust API (complaint form) — optional; form hidden when unset
NEXT_PUBLIC_API_URL=

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ENABLED=false
