# =============================================================================
# ORTAQ Web (Next.js) — public marketing site
# Copy to .env.local for local dev. Set in Vercel per environment.
# NEVER commit secrets. Server secrets live in ortaq-api only.
# =============================================================================

# --- Production (Vercel) — required for ortaq.biz ---
# NEXT_PUBLIC_APP_ENV=production
# NEXT_PUBLIC_SITE_URL=https://ortaq.biz
# NEXT_PUBLIC_ANALYTICS_ENABLED=false
# Do NOT set NEXT_PUBLIC_API_URL until Railway is live.

# --- Local development ---
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Future: ortaq-api on Railway
NEXT_PUBLIC_API_URL=http://localhost:4000
# production: https://api.ortaq.biz

# --- Analytics (privacy-first, off by default) ---
NEXT_PUBLIC_ANALYTICS_ENABLED=false
# plausible | none
NEXT_PUBLIC_ANALYTICS_PROVIDER=none
# NEXT_PUBLIC_ANALYTICS_DOMAIN=ortaq.biz

# --- Error monitoring (server-only, set in Vercel) ---
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=   # CI only, for source maps upload

# --- Vercel (auto-injected, do not set locally) ---
# VERCEL_ENV=production|preview|development
# VERCEL_URL=
