{
  "name": "ortaq-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:clean": "rm -rf .next && next dev --port 3001",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "build:prod": "NEXT_PUBLIC_APP_ENV=production NEXT_PUBLIC_SITE_URL=https://ortaq.biz next build",
    "build:staging": "NEXT_PUBLIC_APP_ENV=staging NEXT_PUBLIC_SITE_URL=https://staging.ortaq.biz next build",
    "validate:prod": "NEXT_PUBLIC_APP_ENV=production NEXT_PUBLIC_SITE_URL=https://ortaq.biz sh -c 'npm run build:prod && node scripts/validate-production.mjs'",
    "validate:staging": "NEXT_PUBLIC_APP_ENV=staging NEXT_PUBLIC_SITE_URL=https://staging.ortaq.biz sh -c 'npm run build:staging && node scripts/validate-staging.mjs'",
    "validate:live:staging": "node scripts/validate-live.mjs staging",
    "validate:live:production": "node scripts/validate-live.mjs production",
    "dns:check": "node scripts/dns-check.mjs",
    "audit:staging": "node scripts/lighthouse-audit.mjs staging",
    "audit:production": "node scripts/lighthouse-audit.mjs production",
    "start": "next start --port 3001",
    "lint": "next lint",
    "check": "tsc --noEmit",
    "generate:favicons": "node scripts/generate-favicon-assets.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.8.13",
    "lucide-react": "^0.545.0",
    "next": "^15.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "typescript": "5.6.3"
  }
}
